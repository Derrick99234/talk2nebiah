generator client {
  provider = "prisma-client-js"
}

 datasource db {
    provider = "postgresql"
  }

 model Admin {
   id           Int    @id @default(autoincrement())
   email        String @unique
   passwordHash String
 }

 model GlobalSettings {
   id               String   @id @default("current")
   singleNaira      Float    @default(15000)
   singleUsd        Float    @default(20)
   monthlyNaira     Float    @default(120000)
   monthlyUsd       Float    @default(150)
   aiSystemPrompt   String   @db.Text
   updatedAt        DateTime @updatedAt
 }

 model User {
   id             String    @id @default(cuid())
   name           String?
   email          String?   @unique
   whatsappNumber String?   @unique
   avatar         String?
   createdAt      DateTime  @default(now())
   updatedAt      DateTime  @updatedAt
   payments       Payment[]
   sessions       Session[]
   authTokens     AuthToken[]
 }

 model AuthToken {
   id        String   @id @default(cuid())
   token     String   @unique
   userId    String
   user      User     @relation(fields: [userId], references: [id])
   expiresAt DateTime
   usedAt    DateTime?
   createdAt DateTime @default(now())
 }

 model Payment {
   id                String   @id @default(cuid())
   userId            String
   user              User     @relation(fields: [userId], references: [id])
   amount            Float
   currency          String   // 'NGN' | 'USD'
   status            String   // 'PENDING' | 'SUCCESSFUL' | 'FAILED'
   paystackReference String   @unique
   planName          String
   geoCountry        String?
   createdAt         DateTime @default(now())
   updatedAt         DateTime @updatedAt
 }

 model Session {
   id               String    @id @default(cuid())
   userId           String
   user             User      @relation(fields: [userId], references: [id])
   struggleCategory String
   status           String    @default("ONGOING") // 'ONGOING' | 'RESOLVED'
   feedbackRating   Int?
   notes            String?
   startDate        DateTime  @default(now())
   resolvedDate     DateTime?
   messages         Message[]
 }

 model Message {
   id         String   @id @default(cuid())
   sessionId  String
   session    Session  @relation(fields: [sessionId], references: [id])
   content    String?
   mediaUrl   String?
   transcript String?
   senderType String   // 'PATIENT' | 'AI' | 'HUMAN'
   timestamp  DateTime @default(now())
 }
