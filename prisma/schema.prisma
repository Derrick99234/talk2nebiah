generator client {
  provider = "prisma-client-js"
}

 datasource db {
    provider = "postgresql"
  }

 model Admin {
   id           Int    @id @default(autoincrement())
   email        String @unique
   passwordHash String
 }

 model GlobalSettings {
   id               String   @id @default("current")
   singleNaira      Float    @default(20000)
   singleUsd        Float    @default(20)
   weeklyNaira      Float    @default(59000)
   weeklyUsd        Float    @default(49.3)
   monthlyNaira     Float    @default(120000)
   monthlyUsd       Float    @default(100)
   aiSystemPrompt   String   @db.Text
   updatedAt        DateTime @updatedAt
 }

 model User {
   id             String    @id @default(cuid())
   name           String?
   email          String?   @unique
   whatsappNumber String?   @unique
   avatar         String?
   createdAt      DateTime  @default(now())
   updatedAt      DateTime  @updatedAt
   payments       Payment[]
   sessions       Session[]
   authTokens     AuthToken[]
 }

 model AuthToken {
   id        String   @id @default(cuid())
   token     String   @unique
   userId    String
   user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
   expiresAt DateTime
   usedAt    DateTime?
   createdAt DateTime @default(now())

   @@index([userId])
 }

 model Payment {
   id                String   @id @default(cuid())
   userId            String
   user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
   amount            Float
   currency          String   // 'NGN' | 'USD'
   status            String   // 'PENDING' | 'SUCCESSFUL' | 'FAILED'
   paystackReference String   @unique
   planName          String
   geoCountry        String?
   createdAt         DateTime @default(now())
   updatedAt         DateTime @updatedAt

   @@index([userId])
 }

  model Session {
    id               String    @id @default(cuid())
    userId           String
    user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    struggleCategory String
    status           String    @default("ONGOING") // 'ONGOING' | 'RESOLVED'
    responderMode    String    @default("AI") // 'AI' | 'HUMAN'
    feedbackRating   Int?
    notes            String?
    startDate        DateTime  @default(now())
    resolvedDate     DateTime?
    messages         Message[]

    @@index([userId])
  }

 model Message {
   id         String   @id @default(cuid())
   sessionId  String
   session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
   content    String?
   mediaUrl   String?
   transcript String?
   senderType String   // 'PATIENT' | 'AI' | 'HUMAN'
   timestamp  DateTime @default(now())

   @@index([sessionId])
}
